# ── LLM 配置（DeepSeek 默认） ──────────────────────────────────────────────────
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ── Ollama 本地模型（免费，零成本） ──────────────────────────────────────────────
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.1

# ── Claude 备用（V5 新增） ──────────────────────────────────────────────────────
# LLM_PROVIDER=claude
# ANTHROPIC_API_KEY=sk-ant-xxx
# CLAUDE_MODEL=claude-sonnet-4-20250514

# ── GPT-4o 备用（V5 新增） ──────────────────────────────────────────────────────
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-xxx
# OPENAI_MODEL=gpt-4o

# ── LLM 自动降级（V5 新增） ────────────────────────────────────────────────────
# 当主 Provider 失败时，自动切换到备用（逗号分隔，按优先级排列）
# LLM_FALLBACK_CHAIN=deepseek,claude,openai

# ── 各 Agent 可单独覆盖模型（可选） ───────────────────────────────────────────
# ARCHITECT_MODEL=deepseek-chat
# WRITER_MODEL=deepseek-chat
# AUDITOR_MODEL=deepseek-reasoner   # 审计用推理模型效果更好
# REVISER_MODEL=deepseek-chat

# ── 写作参数 ───────────────────────────────────────────────────────────────────
DEFAULT_WORDS_PER_CHAPTER=4000
DEFAULT_TEMPERATURE=0.7
AUDITOR_TEMPERATURE=0.0             # 审计员锁温度 0，结果稳定

# ── 选择性审查模式（V5 新增） ──────────────────────────────────────────────────
# all=每章跑全部审查（默认）  light=只跑对话+场景  minimal=只跑审计  adaptive=按风险自适应
# PIPELINE_REVIEW_MODE=all
# 自适应模式下，每N章强制跑一次全量审查
# PIPELINE_REVIEW_FULL_INTERVAL=5
# 章节审计分低于此值触发全量审查（即使在 light/minimal 模式）
# PIPELINE_REVIEW_FORCE_SCORE=70

# ── WebSocket 实时进度（V5 新增） ──────────────────────────────────────────────
# WEBSOCKET_ENABLED=true

# ── 项目根目录 ─────────────────────────────────────────────────────────────────
BOOKS_DIR=./books

# ═══════════════════════════════════════════════════════════════════════════════
# V6 新增配置
# ═══════════════════════════════════════════════════════════════════════════════

# ── Token 费用追踪 ────────────────────────────────────────────────────────────
# 自动记录每次 LLM 调用的 token 消耗，可在 /api/books/{id}/token-usage 查看
# 无需配置，默认启用

# ── 知识库热加载 ──────────────────────────────────────────────────────────────
# 修改 knowledge_base/ 下的文件后，调用 POST /api/books/reload-kb 即可生效
# 无需重启服务

# ── 错误恢复（Checkpoint）────────────────────────────────────────────────────
# 写作中断后自动保存 checkpoint，调用 POST /api/books/{id}/resume 恢复
# checkpoint 文件：books/{book_id}/pipeline_checkpoint.json

# ── 管线参数（可选，不设则用默认值）─────────────────────────────────────────
# PIPELINE_MAX_REVISE_ROUNDS=3       # 最大修订轮数
# PIPELINE_MIROFISH_INTERVAL=5       # MiroFish每N章触发
# PIPELINE_RECENT_SUMMARIES_N=3      # 前情摘要取最近N章
# PIPELINE_DORMANCY_THRESHOLD=5      # 支线掉线预警章数
# PIPELINE_REVIEW_SCORE_FLOOR=75     # 审查问题汇入阈值
# PIPELINE_STYLE_SCORE_FLOOR=80      # 风格修正阈值
# PIPELINE_AUDIT_TENSION_FLOOR=90    # 审计分低于此值调整张力曲线
# PIPELINE_AUDIT_PASS_TOTAL=95       # 审计通过加权总分

# ── 安全配置 ──────────────────────────────────────────────────────────────────
# CORS_ALLOW_ORIGINS=http://localhost:8766,http://127.0.0.1:8766
